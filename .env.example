# Copy to .env and fill in. Do NOT commit .env.

# ── Host gateway IP (the IP your Docker bridge sees the host on) ──
# Used by extra_hosts in docker-compose.yaml to map host.docker.internal
# (which adapters point to for local Ollama at :11434).
# - macOS / Windows Docker Desktop: usually unneeded (built-in alias).
# - OrbStack on macOS: 192.168.64.1 (the in-compose fallback).
# - Linux: run `ip -4 addr show docker0 | grep inet` (typically 172.17.0.1)
#   or set to "host-gateway" to let Docker resolve it.
# Override here when your host IP differs (e.g., custom bridge networks).
HOST_DOCKER_INTERNAL_IP=172.16.2.1

# ── Cloud provider API keys ──
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Ollama Cloud bearer (optional). Set this if you use :*-cloud models
# (e.g., gpt-oss:120b-cloud, qwen3:235b-cloud) routed through a signed-in
# `ollama serve`, or if hitting ollama.com/api directly. Leave empty for
# local-only Ollama — adapters fall back to a non-validated placeholder.
OLLAMA_API_KEY=

# ── Default model per provider ──
# Each adapter reads these via os.environ.get(name, "<in-code fallback>").
# Keep this file as the source of truth — the in-code fallbacks are
# defensive only and will go stale (cloud providers retire models).
# Per-row override via the "model" cell on the matrix UI takes precedence.
DEFAULT_OLLAMA_MODEL=qwen2.5:7b
DEFAULT_OPENAI_MODEL=gpt-4o-mini
DEFAULT_CLAUDE_MODEL=claude-haiku-4-5
DEFAULT_GEMINI_MODEL=gemini-2.0-flash

# ── Per-provider model list override (advanced) ──
# Comma-separated. Overrides the curated list in harness/models.py
# (surfaced via GET /providers/{id}/models and the matrix UI's Model
# dropdown). Loses metadata (display name, tier, capability flags) —
# env-supplied entries get tier="custom". Useful when a new model
# drops before the curated list catches up.
# CHATGPT_MODELS=gpt-4o-mini,gpt-4o,o1-mini,gpt-5-preview
# CLAUDE_MODELS=claude-haiku-4-5,claude-sonnet-4-6,claude-opus-4-7
# GEMINI_MODELS=gemini-2.0-flash,gemini-2.0-pro
# OLLAMA_MODELS=qwen2.5:7b,llama3.1:8b
